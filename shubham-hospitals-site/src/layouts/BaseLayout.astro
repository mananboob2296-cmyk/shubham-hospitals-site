---
// Self-hosted fonts (bundled same-origin — no Google Fonts / gstatic requests)
import '@fontsource/libre-franklin/latin-500.css';
import '@fontsource/libre-franklin/latin-600.css';
import '@fontsource/source-sans-3/latin-400.css';
import '@fontsource/source-sans-3/latin-600.css';
import '@fontsource/source-sans-3/latin-400-italic.css';
import '@fontsource/playfair-display/latin-500.css';
import '@fontsource/playfair-display/latin-500-italic.css';
// Marathi/Devanagari (Ek Type Mukta + Tiro Devanagari Marathi) — declared via our
// own @font-face below (devanagariFaces) instead of the fontsource CSS, because the
// fontsource per-subset files carry no unicode-range. Without a range, any glyph
// missing from the Latin fonts (★ stars, ▾ arrows) forced a ~98 KiB Mukta download
// on English pages. With the range, these fonts load only for Devanagari text.
import muktaDev400 from '@fontsource/mukta/files/mukta-devanagari-400-normal.woff2?url';
import muktaDev500 from '@fontsource/mukta/files/mukta-devanagari-500-normal.woff2?url';
import muktaDev600 from '@fontsource/mukta/files/mukta-devanagari-600-normal.woff2?url';
import muktaDev700 from '@fontsource/mukta/files/mukta-devanagari-700-normal.woff2?url';
import tiroDev400 from '@fontsource/tiro-devanagari-marathi/files/tiro-devanagari-marathi-devanagari-400-normal.woff2?url';
import tiroDev400i from '@fontsource/tiro-devanagari-marathi/files/tiro-devanagari-marathi-devanagari-400-italic.woff2?url';
import '../styles/global.css';
import '../styles/font-fallbacks.css';
// Preload the two above-the-fold-critical fonts (hero h1 = Libre Franklin 600,
// body copy = Source Sans 3 400). ?url resolves the hashed /_astro/ path at build.
import libre600Url from '@fontsource/libre-franklin/files/libre-franklin-latin-600-normal.woff2?url';
import sourceSans400Url from '@fontsource/source-sans-3/files/source-sans-3-latin-400-normal.woff2?url';
import { SITE, CLINIC_SCHEMA } from '../consts';
import { getLangFromUrl, useTranslations, stripLangPrefix } from '../i18n/utils';
import { translatedPaths } from '../i18n/translations';
import { localeCodes, type Lang } from '../i18n/ui';
import LangSwitcher from '../components/LangSwitcher.astro';
import LotusLoader from '../components/LotusLoader.astro';
import { ViewTransitions } from 'astro:transitions';
import WaIcon from '../components/WaIcon.astro';

const DEVANAGARI_RANGE = 'U+0900-097F, U+1CD0-1CF9, U+200C-200D, U+20A8, U+20B9, U+25CC, U+A830-A839, U+A8E0-A8FF';
const devanagariFaces = ([
  ['Mukta', 400, 'normal', muktaDev400],
  ['Mukta', 500, 'normal', muktaDev500],
  ['Mukta', 600, 'normal', muktaDev600],
  ['Mukta', 700, 'normal', muktaDev700],
  ['Tiro Devanagari Marathi', 400, 'normal', tiroDev400],
  ['Tiro Devanagari Marathi', 400, 'italic', tiroDev400i],
] as const)
  .map(([fam, w, s, u]) => `@font-face{font-family:"${fam}";font-style:${s};font-weight:${w};font-display:swap;src:url(${u}) format("woff2");unicode-range:${DEVANAGARI_RANGE}}`)
  .join('');

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  schema?: object[];
  noindex?: boolean;
  preloadImage?: string;
  lang?: Lang;
  // Per-page hreflang overrides (path per locale). When given, only these
  // locales are emitted as alternates and the language switcher uses them.
  altPaths?: Partial<Record<Lang, string>>;
}
const { title, description, ogTitle, ogDescription, ogImage, ogType = 'website', schema = [], noindex = false, preloadImage, lang: langProp, altPaths } = Astro.props;
const lang: Lang = langProp ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// Prefix an English root path (e.g. '/about-us/') for the active language,
// but only if that page is translated — otherwise keep the English URL (no 404).
const tset = lang === 'en' ? null : await translatedPaths(lang);
const L = (p: string) => (tset?.has(p) ? `/${lang}${p}` : p);
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const basePath = stripLangPrefix(Astro.url.pathname);
// Emit hreflang alternates only for locales where this page actually exists.
// When a page provides explicit altPaths (e.g. blog articles) trust those;
// otherwise derive availability from the content collections so we never point
// hreflang at a non-existent /hi/ or /mr/ URL.
let altCodes: Lang[];
if (altPaths) {
  altCodes = (['en', 'hi', 'mr'] as Lang[]).filter((c) => altPaths[c]);
} else {
  const [hiSet, mrSet] = await Promise.all([translatedPaths('hi'), translatedPaths('mr')]);
  altCodes = ['en', ...(hiSet.has(basePath) ? (['hi'] as Lang[]) : []), ...(mrSet.has(basePath) ? (['mr'] as Lang[]) : [])];
}
const alternates: { code: Lang; href: string }[] = altCodes.map((code) => ({
  code,
  href: new URL(altPaths?.[code] ?? (code === 'en' ? basePath : `/${code}${basePath}`), SITE.url).href,
}));

// Department + landing-page labels, localized. Order is shared across locales.
const deptOrder = [
  'advanced-laparoscopy-hysteroscopy',
  'obstetrics-gynecology',
  'ivf-fertility-treatments',
  'ultrasound-imaging',
  'general-surgery-gastroenterology',
  'cosmetic-aesthetic-gynecology',
  'fetal-medicine',
];
const deptNames: Record<Lang, Record<string, string>> = {
  en: {
    'advanced-laparoscopy-hysteroscopy': 'Advanced Laparoscopy & Hysteroscopy',
    'obstetrics-gynecology': 'Obstetrics & Gynecology',
    'ivf-fertility-treatments': 'IVF & Fertility Treatments',
    'ultrasound-imaging': 'Ultrasound & Imaging',
    'general-surgery-gastroenterology': 'General Surgery & Gastroenterology',
    'cosmetic-aesthetic-gynecology': 'Cosmetic & Aesthetic Gynecology',
    'fetal-medicine': 'Fetal Medicine (opening soon)',
  },
  hi: {
    'advanced-laparoscopy-hysteroscopy': 'उन्नत लेप्रोस्कोपी और हिस्टेरोस्कोपी',
    'obstetrics-gynecology': 'प्रसूति एवं स्त्री रोग',
    'ivf-fertility-treatments': 'IVF और प्रजनन उपचार',
    'ultrasound-imaging': 'अल्ट्रासाउंड और इमेजिंग',
    'general-surgery-gastroenterology': 'जनरल सर्जरी और गैस्ट्रोएंटरोलॉजी',
    'cosmetic-aesthetic-gynecology': 'कॉस्मेटिक और सौंदर्य स्त्री रोग',
    'fetal-medicine': 'भ्रूण चिकित्सा (जल्द ही शुरू)',
  },
  mr: {
    'advanced-laparoscopy-hysteroscopy': 'प्रगत लॅपरोस्कोपी व हिस्टेरोस्कोपी',
    'obstetrics-gynecology': 'प्रसूती व स्त्रीरोग',
    'ivf-fertility-treatments': 'IVF व प्रजनन उपचार',
    'ultrasound-imaging': 'अल्ट्रासाऊंड व इमेजिंग',
    'general-surgery-gastroenterology': 'जनरल सर्जरी व गॉस्ट्रोएन्टेरोलॉजी',
    'cosmetic-aesthetic-gynecology': 'कॉस्मेटिक व सौंदर्य स्त्रीरोग',
    'fetal-medicine': 'गर्भ वैद्यकशास्त्र (लवकरच सुरू)',
  },
};
const treatments = deptOrder.map((slug) => ({ slug, title: deptNames[lang][slug] }));

// (T16) SEO "Best X in Amravati" landing pages are intentionally NOT in the primary
// nav dropdown — they remain indexed and linked from the homepage service cards,
// footer/sitemap. Nav shows the 7 real departments only.

// Tagline (SITE.tagline is English; localize for display).
const taglineByLang: Record<Lang, string> = {
  en: SITE.tagline,
  hi: 'हाई-टेक इलाज, वास्तव में किफ़ायती दाम पर!',
  mr: 'हाय-टेक उपचार, खरोखर परवडणार्या दरात!',
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" as="font" type="font/woff2" href={libre600Url} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={sourceSans400Url} crossorigin />
    <style is:inline set:html={devanagariFaces}></style>
    <ViewTransitions />
    <script is:inline>
      // First-visit language routing. Respects a manual choice (lang cookie);
      // otherwise sends Hindi/Marathi browsers to their homepage on the root page only.
      (function () {
        try {
          var path = location.pathname;
          var seg = path.split('/')[1];
          var cur = seg === 'hi' || seg === 'mr' ? seg : 'en';
          var m = document.cookie.match(/(?:^|; )lang=(en|hi|mr)/);
          var pref = m ? m[1] : null;
          if (!pref) {
            var isHome = path === '/' || path === '/hi/' || path === '/mr/';
            if (!isHome) return;
            var n = (navigator.language || '').toLowerCase();
            pref = n.indexOf('hi') === 0 ? 'hi' : n.indexOf('mr') === 0 ? 'mr' : 'en';
          }
          if (pref !== cur) {
            var rest = path.replace(/^\/(hi|mr)(\/|$)/, '/');
            var target = pref === 'en' ? rest : '/' + pref + rest;
            if (target !== path) location.replace(target + location.search + location.hash);
          }
        } catch (e) {}
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={SITE.favicon} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {alternates.map((a) => <link rel="alternate" hreflang={localeCodes[a.code]} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={alternates[0].href} />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} imagesrcset={preloadImage === SITE.heroImage ? SITE.heroSrcset : undefined} imagesizes={preloadImage === SITE.heroImage ? SITE.heroSizes : undefined} fetchpriority="high" />}
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={new URL(ogImage ?? SITE.ogImage, SITE.url).href} />
    <meta property="og:locale" content={localeCodes[lang].replace('-', '_')} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(CLINIC_SCHEMA)} />
    {schema.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div id="lotus-splash" style="display:none"><LotusLoader uid="ls" size={110} /></div>
    <template id="lotus-tpl"><LotusLoader uid="lt" size={96} /></template>
    <script is:inline>
      // First-visit splash: shows the lotus for ~1s, once per browser session.
      // Gated on JS + sessionStorage + prefers-reduced-motion; the div ships
      // display:none so no-JS visitors and crawlers never see it.
      (function () {
        var el = document.getElementById('lotus-splash');
        if (!el) return;
        try {
          if (sessionStorage.getItem('lotusSplashSeen') || matchMedia('(prefers-reduced-motion: reduce)').matches) { el.remove(); return; }
          sessionStorage.setItem('lotusSplashSeen', '1');
          el.style.display = 'flex';
          setTimeout(function () { el.classList.add('done'); setTimeout(function () { el.remove(); }, 380); }, 1000);
        } catch (e) { el.remove(); }
      })();
    </script>
    <header class="site-header">
      <div class="topbar">
        <div class="container">
          <span><svg class="tb-ic" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2"/></svg>{t('topbar.hours')}</span>
          <span class="topbar-right">
            <span><svg class="tb-ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg><a href={SITE.phoneHref}>{SITE.phone}</a> · <svg class="tb-ic" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3.5 7.5l8.5 6 8.5-6"/></svg><a href={`mailto:${SITE.email}`}>{SITE.email}</a></span>
            <LangSwitcher altPaths={altPaths} />
          </span>
        </div>
      </div>
      <div class="container nav-wrap">
        <button type="button" class="nav-burger" aria-label="Menu" aria-expanded="false" aria-controls="main-nav">☰</button>
        <a class="logo" href={L('/')} aria-label={SITE.name}>
          <img src={SITE.logoHeader} alt={`${SITE.name} logo`} width="600" height="212" />
        </a>
        <div class="header-actions">
          <LangSwitcher altPaths={altPaths} />
        </div>
        <nav id="main-nav" class="main-nav" aria-label="Main menu">
          <ul>
            <li><a href={L('/')}>{t('nav.home')}</a></li>
            <li><a href={L('/about-us/')}>{t('nav.about')}</a></li>
            <li class="has-dropdown">
              <a href={L('/departments/')}>{t('nav.departments')}</a>
              <ul class="dropdown">
                {treatments.map((tr) => (
                  <li><a href={L(`/treatments/${tr.slug}/`)}>{tr.title}</a></li>
                ))}
              </ul>
            </li>
            <li><a href={L('/doctors/')}>{t('nav.doctors')}</a></li>
            <li><a href={L('/blogs/')}>{t('nav.blogs')}</a></li>
            <li><a href={L('/faq/')}>{t('nav.faq')}</a></li>
            <li><a href={L('/contact-us/')}>{t('nav.contact')}</a></li>
            <li class="nav-cta"><a class="btn btn-primary" href={L('/contact-us/') + '#book'} style="color:#fff">{t('nav.book')}</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container cols">
        <div>
          <img src={SITE.logoWhite} alt={`${SITE.name} logo`} width="200" height="71" loading="lazy" />
          <p>{taglineByLang[lang]}</p>
          <p>{t('footer.trusted')}</p>
          <div class="social-row">
            <a href={SITE.facebook} rel="noopener" target="_blank" aria-label="Follow us on Facebook">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#1877F2" d="M24 12a12 12 0 1 0-13.88 11.85v-8.38H7.08V12h3.04V9.36c0-3 1.79-4.67 4.53-4.67 1.31 0 2.69.24 2.69.24v2.95h-1.51c-1.49 0-1.96.93-1.96 1.87V12h3.33l-.53 3.47h-2.8v8.38A12 12 0 0 0 24 12z"/></svg>
            </a>
            <a href={SITE.instagram} rel="noopener" target="_blank" aria-label="Follow us on Instagram">
              <svg viewBox="0 0 24 24" aria-hidden="true"><defs><linearGradient id="ig" x1="0" y1="1" x2="1" y2="0"><stop offset="0" stop-color="#FEDA75"/><stop offset=".25" stop-color="#FA7E1E"/><stop offset=".5" stop-color="#D62976"/><stop offset=".75" stop-color="#962FBF"/><stop offset="1" stop-color="#4F5BD5"/></linearGradient></defs><path fill="url(#ig)" d="M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85C2.38 3.92 3.9 2.38 7.15 2.23 8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 2.7.27.27 2.69.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.2 4.36 2.62 6.78 6.98 6.98C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c4.35-.2 6.78-2.62 6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.2-4.35-2.62-6.78-6.98-6.98C15.67.01 15.26 0 12 0zm0 5.84A6.16 6.16 0 1 0 18.16 12 6.16 6.16 0 0 0 12 5.84zM12 16a4 4 0 1 1 4-4 4 4 0 0 1-4 4zm6.41-10.85a1.44 1.44 0 1 0 1.44 1.44 1.44 1.44 0 0 0-1.44-1.44z"/></svg>
            </a>
            <a href={SITE.youtubeHospital} rel="noopener" target="_blank" aria-label="Subscribe on YouTube">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#FF0000" d="M23.5 6.2a3.02 3.02 0 0 0-2.12-2.14C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.51A3.02 3.02 0 0 0 .5 6.2 31.5 31.5 0 0 0 0 12a31.5 31.5 0 0 0 .5 5.8 3.02 3.02 0 0 0 2.12 2.14c1.88.51 9.38.51 9.38.51s7.5 0 9.38-.51a3.02 3.02 0 0 0 2.12-2.14A31.5 31.5 0 0 0 24 12a31.5 31.5 0 0 0-.5-5.8zM9.55 15.57V8.43L15.82 12z"/></svg>
            </a>
            <a href={SITE.google} rel="noopener" target="_blank" aria-label="Read our Google reviews">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M23.49 12.27c0-.79-.07-1.54-.19-2.27H12v4.51h6.47a5.4 5.4 0 0 1-2.4 3.58v3h3.86c2.26-2.09 3.56-5.17 3.56-8.82z"/><path fill="#34A853" d="M12 24c3.24 0 5.95-1.08 7.93-2.91l-3.86-3c-1.08.72-2.45 1.16-4.07 1.16-3.13 0-5.78-2.11-6.73-4.96H1.29v3.09A11.99 11.99 0 0 0 12 24z"/><path fill="#FBBC05" d="M5.27 14.29a7.2 7.2 0 0 1 0-4.58V6.62H1.29a12 12 0 0 0 0 10.76z"/><path fill="#EA4335" d="M12 4.75c1.77 0 3.35.61 4.6 1.8l3.42-3.42A11.97 11.97 0 0 0 12 0 11.99 11.99 0 0 0 1.29 6.62l3.98 3.09C6.22 6.86 8.87 4.75 12 4.75z"/></svg>
            </a>
          </div>
        </div>
        <div>
          <h2>{t('footer.departments')}</h2>
          <ul>
            {treatments.map((tr) => (
              <li><a href={L(`/treatments/${tr.slug}/`)}>{tr.title}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h2>{t('footer.quickLinks')}</h2>
          <ul>
            <li><a href={L('/about-us/')}>{t('footer.aboutUs')}</a></li>
            <li><a href={L('/doctors/')}>{t('footer.ourDoctors')}</a></li>
            <li><a href={L('/blogs/')}>{t('footer.healthBlog')}</a></li>
            <li><a href={L('/faq/')}>{t('nav.faq')}</a></li>
            <li><a href={L('/contact-us/')}>{t('footer.contactDirections')}</a></li>
          </ul>
        </div>
        <div>
          <h2>{t('footer.contact')}</h2>
          <ul>
            <li><svg class="tb-ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s7-5.4 7-11a7 7 0 0 0-14 0c0 5.6 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/></svg><a href={SITE.directions} target="_blank" rel="noopener">{SITE.address}</a></li>
            <li><svg class="tb-ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg><a href={SITE.phoneHref}>{SITE.phone}</a></li>
            <li><svg class="tb-ic" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3.5 7.5l8.5 6 8.5-6"/></svg><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
            <li><svg class="tb-ic" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2"/></svg>{t('footer.hours')}</li>
            <li><svg class="tb-ic" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="4"/><path d="M12 8v8M8 12h8"/></svg>{t('footer.emergency')}</li>
          </ul>
        </div>
      </div>
      <div class="copyright container">
        Copyright © {new Date().getFullYear()} {SITE.name} – {t('footer.rights')}
      </div>
    </footer>

    <div class="fab-group">
      <a class="fab fab-wa" href={SITE.whatsapp} target="_blank" rel="noopener" aria-label="Chat on WhatsApp"><WaIcon /></a>
      <a class="fab fab-call" href={SITE.phoneHref} aria-label={t('cta.callNow')}><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></a>
    </div>
    <script is:inline>
      // Mobile nav — event delegation on document so bindings survive Astro
      // view-transition swaps (elements are replaced; document listeners persist).
      (function () {
        if (window.__navBound) return;
        window.__navBound = true;
        function setOpen(open) {
          var nav = document.getElementById('main-nav');
          var btn = document.querySelector('.nav-burger');
          if (!nav || !btn) return;
          nav.classList.toggle('open', open);
          document.body.classList.toggle('nav-open', open);
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        }
        document.addEventListener('click', function (e) {
          if (e.target.closest('.nav-burger')) {
            var nav = document.getElementById('main-nav');
            setOpen(!(nav && nav.classList.contains('open')));
            return;
          }
          if (e.target.closest('#main-nav a')) setOpen(false);
        });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') setOpen(false); });
      })();
    </script>
    <script is:inline>
      // Lotus loader on slow page transitions: if the next page takes >300ms to
      // prepare, show the lotus overlay (cloned from #lotus-tpl); removed on load.
      (function () {
        if (window.__lotusNavBound) return;
        window.__lotusNavBound = true;
        var timer = null, ov = null;
        function clear() {
          if (timer) { clearTimeout(timer); timer = null; }
          var el = document.getElementById('lotus-splash');
          if (ov && el === ov) el.remove();
          ov = null;
        }
        document.addEventListener('astro:before-preparation', function () {
          if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          clear();
          timer = setTimeout(function () {
            var tpl = document.getElementById('lotus-tpl');
            if (!tpl || document.getElementById('lotus-splash')) return;
            ov = document.createElement('div');
            ov.id = 'lotus-splash';
            ov.appendChild(tpl.content.cloneNode(true));
            document.body.appendChild(ov);
          }, 300);
        });
        document.addEventListener('astro:page-load', clear);
      })();
    </script>
  </body>
</html>
