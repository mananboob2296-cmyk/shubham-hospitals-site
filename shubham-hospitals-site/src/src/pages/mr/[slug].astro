---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqSection from '../../components/FaqSection.astro';
import CtaBand from '../../components/CtaBand.astro';
import { landingContent } from '../../i18n/landing';
import { doctorContent } from '../../i18n/doctors';
import { blogContent } from '../../i18n/blog';
import { useTranslations } from '../../i18n/utils';
import { SITE } from '../../consts';

const lang = 'mr';
const teamEyebrow = 'आमची टीम';
const honorsHeading = 'सन्मान व कामगिरी';
const expertiseHeading = 'तज्ज्ञतेची क्षेत्रे';
const ytLabel = '▶ यूट्यूबवर डॉ. मनन पाहा';
const blogEyebrow = 'हेल्थ ब्लॉग';
const homeLabel = 'मुख्यपृष्ठ';
const blogLabel = 'ब्लॉग';
const disclaimerText = 'अस्वीकरण: हा लेख केवळ सामान्य माहितीसाठी आहे व व्यावसायिक वैद्यकीय सल्ल्याचा पर्याय नाही. कृपया तुमच्या स्थितीनुसार मार्गदर्शनासाठी पात्र डॉक्टरांचा सल्ला घ्या.';
const localeCode = 'mr-IN';

export function getStaticPaths() {
  const L = landingContent.mr ?? {};
  const D = doctorContent.mr ?? {};
  const B = blogContent.mr ?? {};
  return [
    ...Object.keys(L).map((slug) => ({ params: { slug }, props: { kind: 'landing', e: L[slug], slug } })),
    ...Object.keys(D).map((slug) => ({ params: { slug }, props: { kind: 'doctor', e: D[slug], slug } })),
    ...Object.keys(B).map((slug) => ({ params: { slug }, props: { kind: 'blog', e: B[slug], slug } })),
  ];
}

const { kind, e, slug } = Astro.props;
const t = useTranslations(lang);

let pageTitle = '', pageDesc = '', pageSchema: object[] = [], pageOg: string | undefined;
if (kind === 'landing') { pageTitle = e.metaTitle; pageDesc = e.metaDescription; pageOg = e.heroImage; }
else if (kind === 'doctor') { pageTitle = e.metaTitle; pageDesc = e.metaDescription; pageOg = e.photo; }
else {
  pageTitle = `${e.title} | शुभम हॉस्पिटल्स, अमरावती`;
  pageDesc = e.excerpt;
  pageOg = e.image;
  const url = new URL(`/mr/${slug}/`, SITE.url).href;
  pageSchema = [{ '@context': 'https://schema.org', '@type': 'BlogPosting', headline: e.title, description: e.excerpt, datePublished: new Date(e.date).toISOString(), inLanguage: 'mr', author: { '@type': 'Person', name: e.author }, publisher: { '@type': 'Organization', name: SITE.name, logo: { '@type': 'ImageObject', url: SITE.ogImage } }, image: e.image ?? SITE.ogImage, mainEntityOfPage: url }];
  if (e.faqs && e.faqs.length) pageSchema.push({ '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: e.faqs.map((f: { q: string; a: string }) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) });
}
const dateLabel = kind === 'blog' ? new Date(e.date).toLocaleDateString(localeCode, { day: 'numeric', month: 'long', year: 'numeric' }) : '';
---
<BaseLayout
  title={pageTitle}
  description={pageDesc}
  ogTitle={kind === 'landing' ? e.ogTitle : undefined}
  ogDescription={kind === 'landing' ? e.ogDescription : undefined}
  ogType={kind === 'blog' ? 'article' : 'website'}
  ogImage={pageOg}
  schema={pageSchema}
  lang={lang}
>
  {kind === 'landing' && (
    <>
      <section class="hero">
        <div class="container">
          <h1>{e.title}</h1>
          {e.subtitle && <p>{e.subtitle}</p>}
          <div class="btn-row">
            <a class="btn btn-primary" style="color:#fff" href="/mr/contact-us/#book">{t('cta.book')}</a>
            <a class="btn btn-white" href={SITE.phoneHref}>{e.callLabel}</a>
          </div>
        </div>
      </section>
      {e.stats.length > 0 && (
        <section class="section"><div class="container"><div class="stats">
          {e.stats.map((s) => (<div class="stat"><div class="num">{s.value}</div><div class="label">{s.label}</div></div>))}
        </div></div></section>
      )}
      {e.whyChoose.length > 0 && (
        <section class="section soft"><div class="container prose">
          <h2>{e.whyHeading}</h2>
          <ul>{e.whyChoose.map((w) => <li set:html={w.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />)}</ul>
        </div></section>
      )}
      <section class="section"><div class="container prose">
        {e.blocks.map((b) => (
          b.t === 'h2' ? <h2>{b.s}</h2>
          : b.t === 'h3' ? <h3>{b.s}</h3>
          : b.t === 'p' ? <p>{b.s}</p>
          : b.t === 'html' ? <p set:html={b.s} />
          : <ul>{b.items.map((it) => (<li><strong>{it.b}</strong> {it.s}</li>))}</ul>
        ))}
        {e.ctaTreatment && (<p><a class="btn btn-outline" href={e.ctaTreatment}>{e.ctaTreatmentLabel}</a></p>)}
      </div></section>
      <section class="section soft"><div class="container prose">
        <FaqSection faqs={e.faqs} heading={t('faq.heading')} />
      </div></section>
      <CtaBand />
    </>
  )}

  {kind === 'doctor' && (
    <>
      <section class="hero">
        <div class="container">
          <span class="eyebrow">{teamEyebrow}</span>
          <h1>{e.name}</h1>
          <p>{e.qualifications}</p>
          <p><strong style="color:#f0a441">{e.role}</strong></p>
        </div>
      </section>
      <section class="section">
        <div class="container doctor-layout">
          <img src={e.photo} alt={e.name} width="240" height="240" style="border-radius:16px; width:240px; height:auto;" />
          <div class="prose">
            {e.blocks.map((b) => (
              b.t === 'h2' ? <h2>{b.s}</h2>
              : b.t === 'h3' ? <h3>{b.s}</h3>
              : b.t === 'p' ? <p>{b.s}</p>
              : b.t === 'html' ? <p set:html={b.s} />
              : <ul>{b.items.map((it) => (<li><strong>{it.b}</strong> {it.s}</li>))}</ul>
            ))}
            {e.honors && e.honors.length > 0 && (
              <>
                <h2>{honorsHeading}</h2>
                <ul>{e.honors.map((h) => <li>{h}</li>)}</ul>
              </>
            )}
            <h2>{expertiseHeading}</h2>
            <ul>{e.expertise.map((x) => <li>{x}</li>)}</ul>
            {slug === 'dr-manan' && e.youtube && (
              <p><a class="btn btn-primary" style="color:#fff" href={e.youtube} target="_blank" rel="noopener">{ytLabel}</a></p>
            )}
          </div>
        </div>
      </section>
      <CtaBand />
    </>
  )}

  {kind === 'blog' && (
    <>
      <section class="hero">
        <div class="container">
          <span class="eyebrow">{blogEyebrow}</span>
          <h1>{e.title}</h1>
          <p>{dateLabel} · {e.author}</p>
        </div>
      </section>
      <section class="section">
        <div class="container prose">
          <nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/mr/">{homeLabel}</a> › <a href="/mr/blogs/">{blogLabel}</a> › {e.title}</nav>
          {e.image && <img src={e.image} alt={e.imageAlt ?? e.title} style="border-radius:14px; width:100%; height:auto; margin:1rem 0;" />}
          {e.blocks.map((b) => (
            b.t === 'h2' ? <h2>{b.s}</h2>
            : b.t === 'h3' ? <h3>{b.s}</h3>
            : b.t === 'p' ? <p>{b.s}</p>
            : b.t === 'html' ? <p set:html={b.s} />
            : <ul>{b.items.map((it) => (<li><strong>{it.b}</strong> {it.s}</li>))}</ul>
          ))}
          {e.faqs && e.faqs.length > 0 && (<FaqSection faqs={e.faqs} heading={t('faq.heading')} />)}
          <p><em>{disclaimerText}</em></p>
        </div>
      </section>
      <CtaBand />
    </>
  )}
</BaseLayout>
