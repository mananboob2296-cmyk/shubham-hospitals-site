---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { blogContent } from '../../../i18n/blog';

const lang = 'hi';
const posts = Object.entries(blogContent.hi ?? {})
  .map(([slug, e]) => ({ slug, ...e }))
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());
const fmt = (d: string) => new Date(d).toLocaleDateString('hi-IN', { day: 'numeric', month: 'long', year: 'numeric' });
---
<BaseLayout
  title="हेल्थ ब्लॉग | शुभम हॉस्पिटल्स, अमरावती"
  description="अमरावती के डॉक्टरों द्वारा लिखे और चिकित्सकीय रूप से समीक्षित स्वास्थ्य लेख — IVF, गर्भावस्था, स्त्री रोग और सर्जरी सरल भाषा में।"
  lang={lang}
>
  <section class="hero">
    <div class="container">
      <span class="eyebrow">हमारे डॉक्टरों से</span>
      <h1>हेल्थ ब्लॉग</h1>
      <p>अमरावती और विदर्भ के परिवारों के लिए व्यावहारिक, चिकित्सकीय रूप से समीक्षित स्वास्थ्य मार्गदर्शन।</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid cols-3">
        {posts.map((p) => (
          <div class="card post-card">
            <div class="meta">{fmt(p.date)} · {p.author}</div>
            <h3><a href={`/hi/${p.slug}/`}>{p.title}</a></h3>
            <p>{p.excerpt}</p>
            <a class="more" href={`/hi/${p.slug}/`}>लेख पढ़ें →</a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
