---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqSection from '../../components/FaqSection.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';
import { SITE } from '../../consts';

const lang = 'hi';
const teamEyebrow = 'हमारी टीम';
const honorsHeading = 'सम्मान और उपलब्धियां';
const expertiseHeading = 'विशेषज्ञता के क्षेत्र';
const ytLabel = '▶ यूट्यूब पर डॉ. मनन को देखें';

// NOTE: doctor profiles keep their existing live URLs at /hi/<doctor-slug>/
// (not /hi/doctors/<slug>/) — do not change these paths.
export async function getStaticPaths() {
  const strip = (s: string) => s.replace(/^hi\//, '');
  const landing = (await getCollection('landing')).filter((e) => e.slug.startsWith('hi/'));
  const doctors = (await getCollection('doctors')).filter((e) => e.slug.startsWith('hi/'));
  return [
    ...landing.map((e) => ({ params: { slug: strip(e.slug) }, props: { kind: 'landing', entry: e } })),
    ...doctors.map((e) => ({ params: { slug: strip(e.slug) }, props: { kind: 'doctor', entry: e } })),
  ];
}

const { kind, entry } = Astro.props;
const slug = entry.slug.replace(/^hi\//, '');
const e = entry.data;
const { Content } = await entry.render();
const t = useTranslations(lang);
---
<BaseLayout
  title={e.metaTitle}
  description={e.metaDescription}
  ogTitle={kind === 'landing' ? e.ogTitle : undefined}
  ogDescription={kind === 'landing' ? e.ogDescription : undefined}
  ogImage={kind === 'landing' ? e.heroImage : e.photo}
  lang={lang}
>
  {kind === 'landing' && (
    <>
      <section class="hero">
        <div class="container">
          <h1>{e.title}</h1>
          {e.subtitle && <p>{e.subtitle}</p>}
          <div class="btn-row">
            <a class="btn btn-primary" style="color:#fff" href="/hi/contact-us/#book">{t('cta.book')}</a>
            <a class="btn btn-white" href={SITE.phoneHref}>{e.callLabel}</a>
          </div>
        </div>
      </section>
      {e.stats.length > 0 && (
        <section class="section"><div class="container"><div class="stats">
          {e.stats.map((s) => (<div class="stat"><div class="num">{s.value}</div><div class="label">{s.label}</div></div>))}
        </div></div></section>
      )}
      {e.whyChoose.length > 0 && (
        <section class="section soft"><div class="container prose">
          <h2>{e.whyHeading}</h2>
          <ul>{e.whyChoose.map((w) => <li set:html={w.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />)}</ul>
        </div></section>
      )}
      <section class="section"><div class="container prose">
        <Content />
        {e.ctaTreatment && (<p><a class="btn btn-outline" href={e.ctaTreatment}>{e.ctaTreatmentLabel}</a></p>)}
      </div></section>
      <section class="section soft"><div class="container prose">
        <FaqSection faqs={e.faqs} heading={t('faq.heading')} />
      </div></section>
      <CtaBand />
    </>
  )}

  {kind === 'doctor' && (
    <>
      <section class="hero">
        <div class="container">
          <span class="eyebrow">{teamEyebrow}</span>
          <h1>{e.name}</h1>
          <p>{e.qualifications}</p>
          <p><strong style="color:#f0a441">{e.role}</strong></p>
        </div>
      </section>
      <section class="section">
        <div class="container doctor-layout">
          <img src={e.photo} srcset={`${e.photo.replace('-480', '-240')} 240w, ${e.photo} 480w`} sizes="240px" alt={e.name} width="240" height="240" style="border-radius:16px; width:240px; height:auto;" />
          <div class="prose">
            <Content />
            {e.honors && e.honors.length > 0 && (
              <>
                <h2>{honorsHeading}</h2>
                <ul>{e.honors.map((h) => <li>{h}</li>)}</ul>
              </>
            )}
            <h2>{expertiseHeading}</h2>
            <ul>{e.expertise.map((x) => <li>{x}</li>)}</ul>
            {slug === 'dr-manan' && e.youtube && (
              <p><a class="btn btn-primary" style="color:#fff" href={e.youtube} target="_blank" rel="noopener">{ytLabel}</a></p>
            )}
          </div>
        </div>
      </section>
      <CtaBand />
    </>
  )}
</BaseLayout>
