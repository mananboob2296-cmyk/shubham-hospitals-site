---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog'))
  .filter((p) => p.slug.startsWith('en/'))
  .map((p) => ({ slug: p.slug.replace(/^en\//, ''), data: p.data }))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout
  title="Health Blog | Shubham Hospitals, Amravati"
  description="Health articles written and medically reviewed by the doctors at Shubham Hi-Tech Hospital, Amravati — IVF, pregnancy, gynecology and surgery explained simply."
>
  <section class="hero">
    <div class="container">
      <span class="eyebrow">From Our Doctors</span>
      <h1>Health Blog</h1>
      <p>Practical, medically reviewed health guidance for families in Amravati and Vidarbha.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2 class="sr-only">Latest Articles</h2>
      <div class="grid cols-3">
        {posts.map((p) => (
          <div class="card post-card">
            <div class="meta">{p.data.date.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })} · {p.data.author}</div>
            <h3><a href={`/${p.slug}/`}>{p.data.title}</a></h3>
            <p>{p.data.excerpt}</p>
            <a class="more" href={`/${p.slug}/`}>Read article →</a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
