---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
const links = [
  { href: '/', label: 'Home · होम · मुख्यपृष्ठ' },
  { href: '/departments/', label: 'Departments · विभाग · विभाग' },
  { href: '/doctors/', label: 'Doctors · डॉक्टर · डॉक्टर' },
  { href: '/contact-us/', label: 'Contact · संपर्क · संपर्क' },
];
---
<BaseLayout
  title="Page Not Found | Shubham Hospitals"
  description="The page you are looking for could not be found."
  noindex={true}
>
  <section class="section">
    <div class="container" style="text-align:center; max-width:640px; padding:72px 20px;">
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p style="margin:0 0 4px;">The page you're looking for doesn't exist or has moved.</p>
      <p lang="hi" style="margin:0 0 4px;">आप जो पेज खोज रहे हैं वह मौजूद नहीं है या हटा दिया गया है।</p>
      <p lang="mr" style="margin:0 0 24px;">तुम्ही शोधत असलेले पेज अस्तित्वात नाही किंवा हलवले गेले आहे.</p>

      <div class="btn-row" style="justify-content:center; flex-wrap:wrap; gap:10px; margin-bottom:28px;">
        {links.map((l) => (
          <a class="btn btn-outline" href={l.href}>{l.label}</a>
        ))}
      </div>

      <p style="margin:0;">
        Need help now? · अभी मदद चाहिए? · आत्ता मदत हवी?<br />
        <a class="btn btn-primary" style="color:#fff; margin-top:10px;" href={SITE.phoneHref}>
          &#9742; {SITE.phone}
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
