---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppointmentForm from '../../components/AppointmentForm.astro';
import { SITE } from '../../consts';
import { contactContent } from '../../i18n/pages';
const lang = 'mr';
const c = contactContent[lang];
---
<BaseLayout title={c.title} description={c.description} lang={lang}>
  <section class="hero">
    <div class="container">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p>{c.heroLead}</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2 class="sr-only">{c.h1}</h2>
      <div class="grid cols-3">
        <div class="card">
          <h3><svg class="tb-ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>{c.phoneH3}</h3>
          <p><a href={SITE.phoneHref}>{SITE.phone}</a></p>
          <p>{c.phoneNote}</p>
        </div>
        <div class="card">
          <h3><svg class="tb-ic" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3.5 7.5l8.5 6 8.5-6"/></svg>{c.emailH3}</h3>
          <p><a href={`mailto:${SITE.email}`}>{SITE.email}</a></p>
        </div>
        <div class="card">
          <h3><svg class="tb-ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s7-5.4 7-11a7 7 0 0 0-14 0c0 5.6 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>{c.addressH3}</h3>
          <p><a href={SITE.directions} target="_blank" rel="noopener">{SITE.address}</a></p>
          <p>{c.opd}</p>
        </div>
      </div>
    </div>
  </section>
  <section class="section soft">
    <div class="container">
      <div class="grid cols-2">
        <AppointmentForm heading="अपॉइंटमेंट बुक करा" />
        <div>
          <h2>{c.findUs}</h2>
          <iframe src={SITE.mapsEmbed} width="100%" height="380" style="border:0; border-radius:14px;" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Shubham Hospitals location on Google Maps"></iframe>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
