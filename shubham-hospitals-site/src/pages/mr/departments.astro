---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getCollection } from 'astro:content';
import { deptContent } from '../../i18n/pages';
import { treatmentCards } from '../../i18n/home';
import { translatedPaths } from '../../i18n/translations';
const lang = 'mr';
const p = deptContent[lang];
const cards = treatmentCards[lang];
const treatments = (await getCollection('treatments')).filter((e) => !e.slug.includes('/')).sort((a, b) => a.data.order - b.data.order);
const tset = await translatedPaths(lang);
---
<BaseLayout title={p.title} description={p.description} lang={lang}>
  <section class="hero">
    <div class="container">
      <span class="eyebrow">{p.eyebrow}</span>
      <h1>{p.h1}</h1>
      <p>{p.lead}</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2 class="sr-only">{p.h1}</h2>
      <div class="grid cols-3">
        {treatments.map((tr) => {
          const base = `/treatments/${tr.slug}/`;
          const href = tset.has(base) ? `/${lang}${base}` : base;
          return (
          <div class="card">
            <h3>{cards[tr.slug]?.title ?? tr.data.title}</h3>
            <p>{cards[tr.slug]?.blurb ?? tr.data.excerpt}</p>
            <a class="more" href={href}>{p.explore}</a>
          </div>
        )})}
      </div>
    </div>
  </section>
  <CtaBand />
</BaseLayout>
