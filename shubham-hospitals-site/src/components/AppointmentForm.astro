---
import { SITE } from '../consts';
import WaIcon from './WaIcon.astro';
import { getLangFromUrl } from '../i18n/utils';
import { formContent } from '../i18n/pages';
interface Props { heading?: string }
const lang = getLangFromUrl(Astro.url);
const f = formContent[lang];
const { heading = 'Book An Appointment' } = Astro.props;
// WhatsApp number for bookings — hospital main line. No third-party form service:
// the form only opens WhatsApp on the visitor's own phone with a pre-filled message.
const WA_NUMBER = '918668954915';
---
<div id="book" style="scroll-margin-top:120px">
  <h2>{heading}</h2>
  <form class="appointment" id="wa-booking">
    <input type="text" name="name" placeholder={f.name} required />
    <input type="tel" name="mobile" placeholder={f.mobile} pattern="[0-9+ ]{10,15}" required />
    <input type="number" name="age" placeholder={f.age} min="0" max="120" />
    <select name="gender" required>
      <option value="" disabled selected>{f.gender}</option>
      <option>{f.female}</option>
      <option>{f.male}</option>
    </select>
    <select name="source">
      <option value="" disabled selected>{f.source}</option>
      <option>{f.friends}</option>
      <option>{f.family}</option>
      <option>{f.google}</option>
      <option>{f.social}</option>
      <option>{f.other}</option>
    </select>
    <textarea name="issue" rows="4" placeholder={f.issue} required></textarea>
    <button class="btn btn-primary" type="submit"><WaIcon class="btn-ic" />{f.submit}</button>
  </form>
  <p><small>{f.note1} <a href={SITE.phoneHref}>{SITE.phone}</a> {f.note2} <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.</small></p>
</div>

<script define:vars={{ WA_NUMBER }}>
  // Delegated so the handler survives Astro view-transition swaps.
  if (!window.__waBookingBound) {
    window.__waBookingBound = true;
    document.addEventListener('submit', (e) => {
      const form = e.target.closest && e.target.closest('#wa-booking');
      if (!form) return;
      e.preventDefault();
      const f = form;
      const msg = [
        'Hello Shubham Hospitals, I would like to book an appointment.',
        `Name: ${f.name.value}`,
        `Mobile: ${f.mobile.value}`,
        f.age.value ? `Age: ${f.age.value}` : null,
        `Gender: ${f.gender.value}`,
        `Issue: ${f.issue.value}`,
        f.source.value ? `Heard about us via: ${f.source.value}` : null,
      ].filter(Boolean).join('\n');
      const btn = form.querySelector('button[type="submit"]');
      if (btn && !btn.dataset.loading) {
        btn.dataset.loading = '1';
        const orig = btn.innerHTML;
        const tpl = document.getElementById('lotus-tpl');
        if (tpl) {
          btn.innerHTML = '';
          btn.appendChild(tpl.content.cloneNode(true));
          btn.appendChild(document.createTextNode('Opening WhatsApp…'));
        }
        setTimeout(() => { btn.innerHTML = orig; delete btn.dataset.loading; }, 1600);
      }
      window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank', 'noopener');
    });
  }
</script>
