---
import { SITE } from '../consts';
interface Props { heading?: string }
const { heading = 'Book An Appointment' } = Astro.props;
// WhatsApp number for bookings — hospital main line. No third-party form service:
// the form only opens WhatsApp on the visitor's own phone with a pre-filled message.
const WA_NUMBER = '918668954915';
---
<div id="book">
  <h2>{heading}</h2>
  <form class="appointment" id="wa-booking">
    <input type="text" name="name" placeholder="Full Name" required />
    <input type="tel" name="mobile" placeholder="Mobile Number" pattern="[0-9+ ]{10,15}" required />
    <input type="number" name="age" placeholder="Age" min="0" max="120" />
    <select name="gender" required>
      <option value="" disabled selected>Gender</option>
      <option>Female</option>
      <option>Male</option>
    </select>
    <select name="source">
      <option value="" disabled selected>How did you hear about us?</option>
      <option>Friends</option>
      <option>Family</option>
      <option>Google</option>
      <option>Social media</option>
      <option>Other</option>
    </select>
    <textarea name="issue" rows="4" placeholder="What issue are you facing?" required></textarea>
    <button class="btn btn-primary" type="submit"><svg viewBox="0 0 24 24" width="18" height="18" style="vertical-align:-3px;margin-right:8px" aria-hidden="true"><path fill="currentColor" d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 18.13h-.01c-1.53 0-3.03-.41-4.34-1.19l-.31-.18-3.23.85.86-3.15-.2-.32a8.2 8.2 0 0 1-1.26-4.36c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.69 8.24-8.23 8.24zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43-.14-.01-.31-.01-.48-.01-.16 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.25 3.74.59.26 1.06.41 1.42.52.6.19 1.14.16 1.57.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z"/></svg>Book via WhatsApp</button>
  </form>
  <p><small>Submitting opens WhatsApp with your details pre-filled — nothing is sent anywhere else. Prefer to call? <a href={SITE.phoneHref}>{SITE.phone}</a> (24x7 for emergencies) or email <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.</small></p>
</div>

<script define:vars={{ WA_NUMBER }}>
  document.getElementById('wa-booking').addEventListener('submit', (e) => {
    e.preventDefault();
    const f = e.target;
    const msg = [
      'Hello Shubham Hospitals, I would like to book an appointment.',
      `Name: ${f.name.value}`,
      `Mobile: ${f.mobile.value}`,
      f.age.value ? `Age: ${f.age.value}` : null,
      `Gender: ${f.gender.value}`,
      `Issue: ${f.issue.value}`,
      f.source.value ? `Heard about us via: ${f.source.value}` : null,
    ].filter(Boolean).join('\n');
    window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank', 'noopener');
  });
</script>
